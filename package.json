{
  "name": "Nature-Backers-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:seed": "ts-node prisma/seed.ts",
    "prebuild": "rimraf dist",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@aws-sdk/client-lambda": "^3.833.0",
    "@aws-sdk/client-s3": "^3.830.0",
    "@aws-sdk/client-ses": "^3.840.0",
    "@hashgraph/sdk": "^2.81.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@prisma/client": "^6.9.0",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.12",
    "adminjs": "^7.8.16",
    "dotenv": "^16.5.0",
    "ethers": "^6.15.0",
    "exceljs": "^4.4.0",
    "express-formidable": "^1.2.0",
    "google-auth-library": "^10.2.0",
    "hedera-global-indexer": "github:CarbonSustain/cs-indexer-hbar",
    "json2csv": "^6.0.0-alpha.2",
    "multer": "^2.0.1",
    "multer-s3": "^3.0.1",
    "pdfkit": "^0.13.0",
    "pg": "^8.16.0",
    "pptxgenjs": "^3.12.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.99",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^29.5.2",
    "@types/json2csv": "^5.0.7",
    "@types/pdfkit": "^0.14.0",
    "@types/pg": "^8.15.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "hardhat": "^2.24.0",
    "hardhat-gas-reporter": "^1.0.8",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^6.11.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(hedera-global-indexer)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
